{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query-response.schema.json",
  "type": "object",
  "required": ["answer", "traceId", "usedContexts", "compressionSummary"],
  "properties": {
    "answer": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "usedContexts": {
      "type": "object",
      "required": ["sessionSummary", "memories", "resources"],
      "properties": {
        "sessionSummary": {
          "type": "string"
        },
        "memories": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["channel", "type", "content"],
            "properties": {
              "channel": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            }
          }
        },
        "resources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["nodeId", "traceNodeId", "nodePath", "drilldownTrail"],
            "properties": {
              "nodeId": {
                "type": "string"
              },
              "traceNodeId": {
                "type": "string"
              },
              "nodePath": {
                "type": "string"
              },
              "drilldownTrail": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "compressionSummary": {
      "type": "object",
      "required": ["beforeContextChars", "afterContextChars"],
      "properties": {
        "beforeContextChars": {
          "type": "integer"
        },
        "afterContextChars": {
          "type": "integer"
        }
      }
    }
  }
}
